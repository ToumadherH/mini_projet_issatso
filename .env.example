# 🔐 Variables d'Environnement ISSATSO+
# Copiez ce fichier en .env et remplissez les valeurs

# ============================================================
# 🔑 Django
# ============================================================
SECRET_KEY=django-insecure-your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,localhost:3000,localhost:8000

# ============================================================
# 🗄️ Database
# ============================================================

# SQLite (Développement)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# MySQL/XAMPP (activer quand MariaDB 10.5+ est installé)
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=issatso_db
# DB_USER=root
# DB_PASSWORD=
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_CHARSET=utf8mb4
# DB_INIT_COMMAND=SET sql_mode='STRICT_TRANS_TABLES'
# DB_CONN_MAX_AGE=600

# ============================================================
# 🌐 CORS & Frontend
# ============================================================
CORS_ALLOW_ALL_ORIGINS=True
FRONTEND_URL=http://localhost:3000

# ============================================================
# 📧 Email (Optionnel)
# ============================================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True

# ============================================================
# 🔐 JWT Tokens
# ============================================================
JWT_ACCESS_TOKEN_LIFETIME_DAYS=1
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ============================================================
# 📱 Frontend (React)
# ============================================================
REACT_APP_API_URL=http://localhost:8000/api/
REACT_APP_API_TIMEOUT=10000

# ============================================================
# ⚙️ Production (À configurer pour le déploiement)
# ============================================================
ENVIRONMENT=development
# ENVIRONMENT=production

# Valeurs pour production (ne pas utiliser en développement)
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# DEBUG=False
# SECRET_KEY=your-production-secret-key
# DATABASE_URL=mysql://user:password@host:3306/dbname
